generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Organization {
  id                String    @id @default(uuid())
  name              String
  slug              String    @unique
  domain            String?
  logoUrl           String?
  website           String?
  countryCode       String?
  timezone          String    @default("UTC")
  defaultLanguage   String    @default("en")
  billingPlan       String    @default("starter")
  trialEndsAt       DateTime?
  isActive          Boolean   @default(true)
  isAgency          Boolean   @default(false)
  creditsBalance    Int       @default(0)
  meetingsPurchased Int       @default(0)
  meetingsConsumed  Int       @default(0)
  metadata          Json      @default("{}")
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  users             User[]
  campaigns         Campaign[]
  leads             Lead[]
  @@map("organizations")
}

model User {
  id             String    @id @default(uuid())
  supabaseAuthId String    @unique
  organizationId String
  email          String
  fullName       String?
  avatarUrl      String?
  role           String    @default("member")
  language       String    @default("en")
  timezone       String    @default("UTC")
  isActive       Boolean   @default(true)
  lastLoginAt    DateTime?
  onboardingStep Int       @default(0)
  metadata       Json      @default("{}")
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  @@unique([organizationId, email])
  @@map("users")
}

model Campaign {
  id                 String   @id @default(uuid())
  organizationId     String
  createdBy          String
  name               String
  description        String?
  status             String   @default("draft")
  targetGeography    String[]
  targetCompanySizes String[]
  targetJobTitles    String[]
  dailySendLimit     Int      @default(50)
  meetingsTarget     Int?
  revenueTarget      Float?
  language           String   @default("en")
  totalLeads         Int      @default(0)
  emailsSent         Int      @default(0)
  emailsOpened       Int      @default(0)
  emailsReplied      Int      @default(0)
  meetingsBooked     Int      @default(0)
  meetingsQualified  Int      @default(0)
  revenueGenerated   Float    @default(0)
  metadata           Json     @default("{}")
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  organization       Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  leads              Lead[]
  @@map("campaigns")
}

model Lead {
  id              String    @id @default(uuid())
  organizationId  String
  campaignId      String?
  firstName       String?
  lastName        String?
  email           String
  emailVerified   Boolean   @default(false)
  phone           String?
  linkedinUrl     String?
  companyName     String?
  companyDomain   String?
  companySize     String?
  companyCountry  String?
  companyCity     String?
  jobTitle        String?
  seniorityLevel  String?
  department      String?
  isDecisionMaker Boolean?
  status          String    @default("new")
  icpScore        Int?
  sourceType      String?
  metadata        Json      @default("{}")
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  campaign        Campaign?    @relation(fields: [campaignId], references: [id])
  @@unique([organizationId, email])
  @@map("leads")
}